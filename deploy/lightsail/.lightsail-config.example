#!/bin/bash
# AWS Lightsail Deployment Configuration
# Copy this file to .lightsail-config and fill in your values
# This file is gitignored - never commit your actual .lightsail-config

# AWS Lightsail Instance Details
LIGHTSAIL_IP=""                              # Auto-populated by 00-provision-instance.sh after static IP is attached
LIGHTSAIL_INSTANCE_NAME="openclaw-server"    # Instance name in Lightsail console
AWS_REGION="us-east-1"                       # AWS region (us-east-1, us-west-2, etc.)

# Instance Provisioning (used by 00-provision-instance.sh)
# Run: ./00-provision-instance.sh  — creates all resources below idempotently
LIGHTSAIL_KEY_PAIR_NAME="openclaw-key"            # Key pair name in Lightsail
LIGHTSAIL_BLUEPRINT_ID="ubuntu_22_04"             # OS blueprint (ubuntu_22_04, ubuntu_24_04)
LIGHTSAIL_BUNDLE_ID="small_3_0"                   # Instance size: nano_3_0=512MB, micro_3_0=1GB, small_3_0=2GB
LIGHTSAIL_STATIC_IP_NAME="openclaw-static-ip"     # Name for the static IP resource

# AWS credentials — set via environment variables, NOT stored here:
#   export AWS_ACCESS_KEY_ID=AKIA...
#   export AWS_SECRET_ACCESS_KEY=...
#   export AWS_DEFAULT_REGION=us-east-1
# Or use a named profile:
#   export AWS_PROFILE=openclaw

# Initial SSH Configuration (for fresh Ubuntu servers)
INITIAL_SSH_USER="ubuntu"                    # Default Ubuntu user (before hardening)
INITIAL_SSH_PORT="22"                        # Default SSH port (before hardening)

# Final SSH Configuration (after hardening - auto-updated by scripts)
SSH_USER="openclaw"                          # Hardened user (set by 01-harden-server.sh)
SSH_PORT="2222"                              # Hardened SSH port (set by 01-harden-server.sh)

# SSH Key
SSH_KEY="$HOME/.ssh/lightsail-key.pem"        # Path to your SSH private key (.pem file)

# Tailscale Configuration (filled after SOP-03)
TAILSCALE_IP=""                              # Tailscale IP address (100.x.x.x format)
# TAILSCALE_AUTH_KEY is stored in secrets/tailscale_auth_key (gitignored), not here
# Generate at: https://login.tailscale.com/admin/settings/keys (use Reusable key)

# Deployment Paths
REMOTE_HOME="/home/openclaw"                 # Remote user home directory
REMOTE_REPO_PATH="/home/openclaw/openclaw"   # Path to cloned repository on server
REMOTE_CONFIG_PATH="/home/openclaw/openclaw/clawctl.toml"  # Remote config file path

# Local Paths (auto-detected, but can override)
LOCAL_REPO_PATH="$(git rev-parse --show-toplevel 2>/dev/null || echo '')"  # Auto-detected from git
LOCAL_DEPLOY_DIR="deploy/lightsail"          # This directory (relative to repo root)

# S3 Configuration (optional, for future S3 sync)
S3_BUCKET=""                                 # S3 bucket name for backups
S3_PREFIX="openclaw-backups"                 # S3 key prefix for backups
S3_REGION="us-east-1"                        # S3 bucket region

# Snapshot Configuration (optional)
SNAPSHOT_PREFIX="openclaw"                   # Prefix for snapshot names
KEEP_SNAPSHOTS=7                             # Number of snapshots to keep

# Security
ALLOWED_SSH_IPS=""                           # Comma-separated IPs for SSH (optional, for additional restrictions)

# Discord / Channel Tokens
# These are NOT stored here - they live in secrets/<username>/discord_token
# Run: ./scripts/set-discord-token.sh <username>
# Or set DISCORD_TOKEN env var for automation: DISCORD_TOKEN=xxx ./scripts/set-discord-token.sh alice

# Model Provider Configuration (optional, for reference)
# ANTHROPIC_API_KEY=""                       # Stored in secrets/, not here
# OPENROUTER_API_KEY=""                      # Stored in secrets/, not here
